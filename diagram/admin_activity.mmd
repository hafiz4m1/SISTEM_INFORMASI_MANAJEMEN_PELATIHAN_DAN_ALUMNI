flowchart TD
    Start([Mulai])
    
    subgraph Admin["Admin"]
        direction TB
        A[Login]
        B[Lihat Dashboard]
        C[Verifikasi<br/>Pendaftaran]
        D[Kelola<br/>Pelatihan]
        E[Kelola<br/>Peserta]
        F[Lihat Laporan]
        G[Logout]
    end
    
    subgraph System["Sistem/Aplikasi"]
        direction TB
        X[Autentikasi<br/>Login]
        Y[Tampilkan<br/>Dashboard]
        Z[Data Verifikasi<br/>Tersimpan]
        W[Data Pelatihan<br/>Tersimpan]
        V[Data Peserta<br/>Tersimpan]
        U[Laporan<br/>Tersedia]
    end
    
    End([Selesai])
    
    Start --> A
    A -->|Login Data| X
    X -->|Login Berhasil| Y
    Y --> B
    B --> C
    C -->|Verifikasi Data| Z
    Z -->|Verifikasi Selesai| D
    D -->|Update Data| W
    W -->|Update Selesai| E
    E -->|Ubah Data| V
    V -->|Update Selesai| F
    F -->|Request Laporan| U
    U -->|Laporan Tersimpan| G
    G --> End
