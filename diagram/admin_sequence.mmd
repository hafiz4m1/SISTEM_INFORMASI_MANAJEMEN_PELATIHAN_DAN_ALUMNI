    %% Admin sequence diagram
    title Diagram Urutan - Admin
    autonumber
    participant Admin as Admin
    participant HalamanLogin as Halaman Login
    participant HalamanDashboard as Halaman Dashboard
    participant HalamanPelatihan as Halaman Pelatihan
