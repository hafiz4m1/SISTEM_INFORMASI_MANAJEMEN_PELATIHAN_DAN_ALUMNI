flowchart TD
    Start([Mulai])
    
    subgraph Peserta["Peserta"]
        direction TB
        A[Login]
        B[Lihat Pelatihan<br/>Tersedia]
        C{Ingin<br/>Mendaftar?}
        D[Daftar Pelatihan]
        E[Cek Status<br/>Kelulusan]
        F[Download<br/>Sertifikat]
        G[Lihat Hasil<br/>Laporan]
    end
    
    subgraph System["Sistem/Aplikasi"]
        direction TB
        X[Proses<br/>Pendaftaran]
        Y[Surat Pendaftaran<br/>Tersimpan]
        Z[Update Status<br/>Peserta]
        W[Sertifikat<br/>Tersimpan]
    end
    
    End([Selesai])
    
    Start --> A
    A --> B
    B --> C
    C -->|Ya| D
    C -->|Tidak| E
    D -->|Daftar Data| X
    X --> Y
    Y -->|Pendaftaran Berhasil| E
    E -->|Status Update| Z
    Z -->|Sudah Lulus| F
    F -->|Sertifikat| W
    W --> G
    G --> End
